---
import { getCollection } from "astro:content";
import FormattedDate from "../../components/FormattedDate.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title={`${SITE_TITLE} — Blog`} description={SITE_DESCRIPTION}>
  <section class="mt-2 sm:mt-4">
    <ul class="divide-y divide-border/80">
      {
        posts.map((post) => (
          <li class="py-4 sm:py-5">
            <a
              href={`/blog/${post.id}/`}
              class="group grid gap-1.5 no-underline sm:grid-cols-[minmax(0,8.75rem)_1fr] sm:items-start sm:gap-4"
            >
              <p class="font-mono text-xs tracking-[0.01em] text-primary sm:pt-1">
                <FormattedDate date={post.data.pubDate} />
              </p>
              <h2 class="font-heading text-lg leading-7 font-semibold text-foreground transition-colors duration-200 group-hover:text-primary sm:text-[1.35rem]">
                <span class="underline decoration-dashed underline-offset-4 transition-[text-decoration-style] duration-200 group-hover:decoration-solid">
                  {post.data.title}
                </span>
              </h2>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>
