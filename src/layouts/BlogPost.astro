---
import { Image } from "astro:assets";
import type { MarkdownHeading } from "astro";
import type { CollectionEntry } from "astro:content";
import BaseHead from "@/components/BaseHead.astro";
import BlogPostInlineToc from "@/components/BlogPostInlineToc.astro";
import BlogPostRail from "@/components/BlogPostRail.astro";
import CopyCodeButton from "@/components/CopyCodeButton.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import { getInlineTocGroups, getRailTocGroups } from "@/lib/blog-toc";

type Props = CollectionEntry<"blog">["data"] & {
    headings: MarkdownHeading[];
};

const { title, description, pubDate, updatedDate, heroImage, headings } =
    Astro.props as Props;

const inlineTocGroups = getInlineTocGroups(headings);
const railTocGroups = getRailTocGroups(headings);

const articleContainerClass = "mx-auto w-full max-w-3xl";
const proseClass =
    "blog-prose prose prose-neutral dark:prose-invert max-w-none text-base leading-8 text-foreground prose-p:my-0 prose-p:mb-4 prose-headings:font-heading prose-headings:font-semibold prose-headings:tracking-tight prose-headings:text-foreground prose-h1:mt-20 prose-h1:mb-5 prose-h1:border-b prose-h1:border-border prose-h1:pb-3 prose-h1:text-4xl prose-h2:mt-14 prose-h2:mb-4 prose-h2:border-b prose-h2:border-border prose-h2:pb-2 prose-h2:text-3xl prose-h3:mt-10 prose-h3:mb-3 prose-h3:text-2xl prose-h4:mt-7 prose-h4:mb-3 prose-h4:text-xl prose-a:text-primary prose-a:underline prose-a:underline-offset-4 [&_a:hover]:text-accent-foreground prose-strong:text-foreground prose-strong:font-semibold prose-ul:my-3 prose-ul:list-disc prose-ul:list-outside prose-ul:pl-6 prose-ol:my-3 prose-ol:list-decimal prose-ol:list-outside prose-ol:pl-6 prose-li:my-0.5 prose-li:marker:text-muted-foreground prose-hr:my-8 prose-hr:border-border [&_h1[id]]:scroll-mt-6 [&_h2[id]]:scroll-mt-6 [&_h3[id]]:scroll-mt-6 [&_h4[id]]:scroll-mt-6 [&_h5[id]]:scroll-mt-6 [&_h6[id]]:scroll-mt-6 [&_img]:my-6 [&_img]:rounded-xl";
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
    </head>

    <body id="top" class="bg-background text-foreground">
        <BlogPostRail groups={railTocGroups} />

        <div class="mx-auto w-full max-w-4xl px-6 pb-16 pt-6">
            <main class={articleContainerClass}>
                <a
                    href="/blog"
                    class="inline-flex items-center rounded-full text-sm text-muted-foreground no-underline transition-colors duration-200 hover:text-foreground"
                >
                    Back
                </a>

                <article class="mt-6">
                    {
                        heroImage && (
                            <figure class="mb-6 overflow-hidden rounded-2xl border border-border bg-card">
                                <Image
                                    width={1020}
                                    height={510}
                                    src={heroImage}
                                    alt=""
                                />
                            </figure>
                        )
                    }

                    <header class="mb-12 text-center">
                        <p class="m-0 text-sm text-muted-foreground">
                            <FormattedDate date={pubDate} />
                        </p>
                        {
                            updatedDate && (
                                <p class="mt-1 text-xs text-muted-foreground">
                                    Updated <FormattedDate date={updatedDate} />
                                </p>
                            )
                        }
                        <h1 class="mt-4 text-balance font-heading text-4xl font-semibold leading-tight tracking-tight md:text-5xl">
                            {title}
                        </h1>
                        {
                            description && (
                                <p class="mx-auto mt-4 max-w-2xl text-pretty text-base leading-8 text-muted-foreground">
                                    {description}
                                </p>
                            )
                        }
                        <div class="mx-auto mt-5 h-px w-40 bg-border"></div>
                    </header>

                    <BlogPostInlineToc groups={inlineTocGroups} />

                    <div class={proseClass}>
                        <slot />
                    </div>
                </article>
            </main>

            <div class={`${articleContainerClass} mt-24 border-t border-border pt-6 text-center text-xs text-muted-foreground`}>
                <Footer />
            </div>
        </div>

        <CopyCodeButton />
    </body>
</html>
