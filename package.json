{
    "name": "sreyas.is",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "predev": "\"$npm_execpath\" --bun ./scripts/mount-blog.ts",
        "prebuild": "\"$npm_execpath\" --bun ./scripts/mount-blog.ts",
        "dev": "\"$npm_execpath\" --bun ./node_modules/.bin/astro dev",
        "build": "\"$npm_execpath\" --bun ./node_modules/.bin/astro build",
        "preview": "\"$npm_execpath\" --bun ./node_modules/.bin/astro preview",
        "astro": "\"$npm_execpath\" --bun ./node_modules/.bin/astro",
        "typecheck": "\"$npm_execpath\" --bun ./node_modules/.bin/astro check",
        "fmt": "\"$npm_execpath\" --bun ./node_modules/.bin/biome format --write .",
        "lint": "\"$npm_execpath\" --bun ./node_modules/.bin/biome lint .",
        "check": "\"$npm_execpath\" --bun ./node_modules/.bin/biome check --write .",
        "ci": "\"$npm_execpath\" run lint && \"$npm_execpath\" run fmt && \"$npm_execpath\" run typecheck"
    },
    "dependencies": {
        "@astrojs/mdx": "^4.3.12",
        "@astrojs/react": "^4.4.2",
        "@astrojs/rss": "^4.0.14",
        "@astrojs/sitemap": "^3.6.0",
        "@fontsource-variable/geist": "^5.2.8",
        "@fontsource/dela-gothic-one": "^5.2.7",
        "@fontsource/eb-garamond": "^5.2.7",
        "@fontsource/inter": "^5.2.8",
        "@fontsource/iosevka": "^5.2.5",
        "@fontsource/literata": "^5.2.8",
        "@fontsource/space-grotesk": "^5.2.10",
        "@fontsource/spectral": "^5.2.8",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "4.2.2",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "astro": "^5.16.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "katex": "^0.16.11",
        "lucide-react": "^1.7.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.1",
        "react-dom": "^19.2.1",
        "rehype-katex": "^7.0.0",
        "remark-math": "^6.0.0",
        "shadcn": "^4.1.0",
        "sharp": "^0.34.5",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "4.2.2",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.8",
        "@astrojs/language-server": "^2.16.6",
        "@astrojs/ts-plugin": "^1.10.7",
        "@biomejs/biome": "^2.3.11",
        "@types/node": "^25.5.0",
        "prettier": "^3.8.1",
        "prettier-plugin-astro": "^0.14.1",
        "typescript": "5.9.3",
        "typescript-language-server": "^5.1.3"
    }
}
