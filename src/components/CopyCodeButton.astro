<script>
    function initCopyButtons() {
        const codeBlocks = document.querySelectorAll("pre.astro-code");
        const baseClasses = [
            "absolute",
            "right-3",
            "top-3",
            "z-10",
            "rounded-md",
            "border",
            "border-border/70",
            "bg-background/90",
            "px-2",
            "py-1",
            "font-mono",
            "text-xs",
            "text-muted-foreground",
            "opacity-0",
            "transition-opacity",
            "duration-200",
            "group-hover/code:opacity-100",
            "focus-visible:opacity-100",
            "hover:bg-secondary",
            "hover:text-foreground",
        ].join(" ");
        const copiedClasses = ["bg-primary", "text-primary-foreground"].join(
            " ",
        );

        codeBlocks.forEach((block) => {
            if (block.querySelector("[data-copy-button]")) return;

            const button = document.createElement("button");
            button.className = baseClasses;
            button.textContent = "Copy";
            button.setAttribute("aria-label", "Copy code to clipboard");
            button.setAttribute("data-copy-button", "true");

            button.addEventListener("click", async () => {
                const code = block.querySelector("code");
                if (!code) return;

                try {
                    await navigator.clipboard.writeText(code.textContent || "");
                    button.textContent = "Copied!";
                    copiedClasses.split(" ").forEach((className) => {
                        button.classList.add(className);
                    });

                    setTimeout(() => {
                        button.textContent = "Copy";
                        copiedClasses.split(" ").forEach((className) => {
                            button.classList.remove(className);
                        });
                    }, 2000);
                } catch (err) {
                    console.error("Failed to copy:", err);
                    button.textContent = "Error";
                }
            });

            block.classList.add("group/code", "relative");
            block.appendChild(button);
        });
    }

    // Run on page load
    document.addEventListener("DOMContentLoaded", initCopyButtons);

    // Run on Astro page transitions (if using View Transitions)
    document.addEventListener("astro:page-load", initCopyButtons);
</script>
