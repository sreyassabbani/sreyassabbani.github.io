---
import ProfileImage from "../../public/pfp.png";
import { SITE_TITLE } from "../consts";
import Layout from "../layouts/Layout.astro";

const projectAreas = [
  {
    title: "Writing and Notes",
    description:
      "Longer notes and posts on math, physics, and whatever else I am trying to understand properly.",
  },
  {
    title: "Software Experiments",
    description:
      "Small tools, website work, and programming detours that seem interesting enough to build.",
  },
  {
    title: "Learning in Public",
    description:
      "A running record of things I am still figuring out, rather than a polished catalogue of finished work.",
  },
];
---

<Layout
  title={`${SITE_TITLE} — About`}
  description="More about Sreyas Sabbani and the projects he is working on."
>
  <section class="space-y-12">
    <section class="border-b border-border pb-10">
      <div class="flex flex-col gap-8 md:flex-row md:items-start">
        <figure class="flex shrink-0 flex-col items-center gap-3 md:w-40">
          <img
            src={ProfileImage.src}
            alt="Photo of Sreyas Sabbani"
            class="size-28 rounded-full object-cover opacity-90 [filter:grayscale(100%)_sepia(40%)_hue-rotate(190deg)_saturate(180%)_brightness(0.85)] dark:[filter:grayscale(100%)_sepia(30%)_hue-rotate(180deg)_saturate(150%)_brightness(1.1)]"
          />
          <figcaption class="text-sm text-muted-foreground">me</figcaption>
        </figure>

        <div class="flex-1 space-y-4">
          <p class="text-sm text-muted-foreground">About</p>
          <h1 class="font-heading text-[clamp(2rem,1.55rem+1.2vw,2.8rem)] leading-tight tracking-[-0.03em] text-foreground">
            Sreyas Sabbani
          </h1>
          <p class="max-w-2xl text-[1.02rem] leading-8 text-muted-foreground">
            I am a math, physics, and computer science enthusiast. Most of what
            I enjoy doing comes down to learning carefully, making things, and
            following ideas until they become concrete.
          </p>
          <p class="max-w-2xl text-[1.02rem] leading-8 text-muted-foreground">
            This site is a place for that process: notes, experiments,
            occasional insights, and sometimes jokes that I find funny.
          </p>
        </div>
      </div>
    </section>

    <section id="projects" class="space-y-5">
      <div class="space-y-2">
        <h2 class="font-heading text-[1.75rem] leading-tight tracking-[-0.025em] text-foreground">
          Projects
        </h2>
        <p class="max-w-2xl text-[0.98rem] leading-7 text-muted-foreground">
          Mostly small, ongoing things rather than a grand showcase.
        </p>
      </div>

      <div class="grid gap-4">
        {projectAreas.map((area) => (
          <article class="rounded-2xl border border-border/80 bg-card/35 px-5 py-4">
            <h3 class="font-heading text-[1.08rem] leading-tight text-foreground">
              {area.title}
            </h3>
            <p class="mt-2 text-[0.97rem] leading-7 text-muted-foreground">
              {area.description}
            </p>
          </article>
        ))}
      </div>
    </section>
  </section>
</Layout>
