---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import type { MarkdownHeading } from "astro";
import BaseHead from "@/components/BaseHead.astro";
import CopyCodeButton from "@/components/CopyCodeButton.astro";
import Footer from "@/components/Footer.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import { Button } from "@/components/ui/button";
import { Separator } from "@/components/ui/separator";
import { cn } from "@/lib/utils";

type Props = CollectionEntry<"blog">["data"] & {
    headings: MarkdownHeading[];
};

type TocItem = {
    slug: string;
    text: string;
};

type TocGroup = {
    heading: TocItem;
    children: TocItem[];
};

const { title, description, pubDate, updatedDate, heroImage, headings } =
    Astro.props as Props;

const filteredHeadings = headings
    .filter(({ depth }) => depth >= 2 && depth <= 3)
    .map(({ depth, slug, text }) => ({ depth, slug, text }));

const tocGroups: TocGroup[] = [];

for (const heading of filteredHeadings) {
    if (heading.depth === 2 || tocGroups.length === 0) {
        tocGroups.push({
            heading: { slug: heading.slug, text: heading.text },
            children: [],
        });
        continue;
    }

    tocGroups[tocGroups.length - 1].children.push({
        slug: heading.slug,
        text: heading.text,
    });
}

const tocEntries =
    tocGroups.length > 0
        ? tocGroups
        : [{ heading: { slug: "top", text: "Top" }, children: [] }];

const railClass = cn(
    "group/tocrail",
    "fixed",
    "inset-y-0",
    "left-0",
    "z-20",
    "hidden",
    "w-56",
    "min-[1100px]:block",
);

const railPanelClass = cn(
    "pointer-events-none",
    "absolute",
    "left-0",
    "top-1/2",
    "max-h-[calc(100vh-2rem)]",
    "w-[13.25rem]",
    "-translate-x-[86%]",
    "-translate-y-1/2",
    "overflow-y-auto",
    "rounded-r-[0.95rem]",
    "border-y",
    "border-r",
    "border-border",
    "bg-[color:color-mix(in_oklab,var(--card)_94%,var(--secondary))]",
    "px-[0.7rem]",
    "py-3",
    "opacity-0",
    "transition-[transform,opacity]",
    "duration-[520ms]",
    "ease-[cubic-bezier(0.22,1,0.36,1)]",
    "group-hover/tocrail:pointer-events-auto",
    "group-hover/tocrail:translate-x-0",
    "group-hover/tocrail:opacity-100",
    "group-hover/tocrail:duration-[340ms]",
    "group-data-[open=true]/tocrail:pointer-events-auto",
    "group-data-[open=true]/tocrail:translate-x-0",
    "group-data-[open=true]/tocrail:opacity-100",
    "group-data-[open=true]/tocrail:duration-[340ms]",
);

const tocGroupLinkClass = cn(
    "block",
    "rounded-[0.55rem]",
    "px-[0.35rem]",
    "py-[0.2rem]",
    "text-[0.76rem]",
    "leading-[1.4]",
    "text-muted-foreground",
    "no-underline",
    "transition-colors",
    "duration-200",
    "hover:bg-secondary/75",
    "hover:text-foreground",
    "data-[active=true]:bg-secondary/90",
    "data-[active=true]:text-foreground",
);

const tocChildListClass = cn(
    "ml-[0.55rem]",
    "mt-0",
    "max-h-0",
    "overflow-hidden",
    "border-l",
    "border-transparent",
    "pl-[0.55rem]",
    "opacity-0",
    "transition-[max-height,opacity,border-color,margin-top]",
    "duration-[360ms]",
    "ease-[cubic-bezier(0.22,1,0.36,1)]",
    "group-data-[open=true]/tocgroup:mt-[0.16rem]",
    "group-data-[open=true]/tocgroup:max-h-48",
    "group-data-[open=true]/tocgroup:border-border",
    "group-data-[open=true]/tocgroup:opacity-100",
);

const tocChildLinkClass = cn(
    "block",
    "rounded-[0.55rem]",
    "px-[0.35rem]",
    "py-[0.2rem]",
    "text-[0.7rem]",
    "leading-[1.35]",
    "text-muted-foreground",
    "no-underline",
    "transition-colors",
    "duration-200",
    "hover:bg-secondary/75",
    "hover:text-foreground",
    "data-[active=true]:bg-secondary/90",
    "data-[active=true]:text-foreground",
);

const proseClass = cn(
    "blog-prose",
    "prose",
    "prose-neutral",
    "dark:prose-invert",
    "max-w-none",
    "text-[1.05rem]",
    "leading-8",
    "text-foreground",
    "prose-p:my-0",
    "prose-p:mb-5",
    "prose-headings:font-heading",
    "prose-headings:font-semibold",
    "prose-headings:tracking-[-0.02em]",
    "prose-headings:text-[color:oklch(0.315_0.036_261.27)]",
    "dark:prose-headings:text-foreground",
    "prose-h2:mt-10",
    "prose-h2:mb-4",
    "prose-h2:border-b",
    "prose-h2:border-border",
    "prose-h2:pb-1.5",
    "prose-h2:text-[1.75rem]",
    "prose-h3:mt-8",
    "prose-h3:mb-3",
    "prose-h3:text-[1.4rem]",
    "prose-h4:mt-6",
    "prose-h4:mb-3",
    "prose-h4:text-[1.15rem]",
    "prose-a:text-primary",
    "prose-a:underline",
    "prose-a:underline-offset-[3px]",
    "[&_a:hover]:text-accent-foreground",
    "prose-strong:text-foreground",
    "prose-strong:font-semibold",
    "prose-ul:my-4",
    "prose-ul:list-disc",
    "prose-ul:pl-6",
    "prose-ol:my-4",
    "prose-ol:list-decimal",
    "prose-ol:pl-6",
    "prose-li:my-2",
    "prose-li:marker:text-muted-foreground",
    "prose-hr:my-8",
    "prose-hr:border-border",
    "[&_h2[id]]:scroll-mt-6",
    "[&_h3[id]]:scroll-mt-6",
    "[&_h4[id]]:scroll-mt-6",
    "[&_h5[id]]:scroll-mt-6",
    "[&_h6[id]]:scroll-mt-6",
    "[&_img]:my-6",
    "[&_img]:rounded-xl",
);
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
    </head>

    <body id="top" class="bg-background text-foreground">
        <aside class={railClass} data-toc-rail aria-label="Post sections">
            <div
                class="pointer-events-auto absolute inset-y-0 left-0 w-[1.8rem]"
                aria-hidden="true"
            ></div>
            <div class={railPanelClass}>
                <nav>
                    <ul class="m-0 list-none p-0">
                        {tocEntries.map((group) => (
                            <li
                                class="group/tocgroup mt-[0.16rem] first:mt-0"
                                data-toc-group={group.heading.slug}
                                data-has-children={
                                    group.children.length > 0
                                        ? "true"
                                        : "false"
                                }
                            >
                                <a
                                    class={tocGroupLinkClass}
                                    href={`#${group.heading.slug}`}
                                    data-toc-link={group.heading.slug}
                                >
                                    {group.heading.text}
                                </a>
                                <ul
                                    class={tocChildListClass}
                                    data-toc-children={group.heading.slug}
                                >
                                    {group.children.map((child) => (
                                        <li class="mt-[0.08rem] first:mt-0">
                                            <a
                                                class={tocChildLinkClass}
                                                href={`#${child.slug}`}
                                                data-toc-link={child.slug}
                                                data-parent-slug={group.heading.slug}
                                            >
                                                {child.text}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>
        </aside>

        <div class="mx-auto w-full max-w-[48rem] px-6 pb-12 pt-6">
            <main>
                <div class="mx-auto mb-6 w-full max-w-[46rem]">
                    <Button
                        asChild
                        variant="ghost"
                        size="sm"
                        className="h-auto rounded-full px-0 py-0 text-[0.88rem] font-normal text-muted-foreground shadow-none hover:bg-transparent hover:text-foreground"
                    >
                        <a href="/blog">Back</a>
                    </Button>
                </div>

                <article>
                    {
                        heroImage && (
                            <figure class="mx-auto mb-6 w-full max-w-[46rem] overflow-hidden rounded-2xl border border-border bg-card">
                                <Image
                                    width={1020}
                                    height={510}
                                    src={heroImage}
                                    alt=""
                                />
                            </figure>
                        )
                    }

                    <header class="mx-auto mb-12 w-full max-w-[46rem] text-center">
                        <p class="m-0 text-[0.9rem] text-muted-foreground">
                            <FormattedDate date={pubDate} />
                        </p>
                        {
                            updatedDate && (
                                <p class="mt-[0.32rem] text-[0.82rem] text-muted-foreground">
                                    Updated <FormattedDate date={updatedDate} />
                                </p>
                            )
                        }
                        <h1 class="mt-4 font-heading text-[clamp(2.1rem,1.55rem+1.55vw,3rem)] leading-[1.02] tracking-[-0.04em] text-balance">
                            {title}
                        </h1>
                        {
                            description && (
                                <p class="mx-auto mt-4 max-w-[35rem] text-pretty text-base leading-[1.72] text-muted-foreground">
                                    {description}
                                </p>
                            )
                        }
                        <Separator className="mx-auto mt-5 w-[min(15rem,34%)]" />
                    </header>

                    <div class={`mx-auto w-full max-w-[46rem] ${proseClass}`}>
                        <slot />
                    </div>
                </article>
            </main>

            <div class="mx-auto mt-[6.4rem] w-full max-w-[46rem] border-t border-border pt-6 text-center text-[0.82rem] text-[color:color-mix(in_oklab,var(--foreground)_42%,var(--background))]">
                <Footer />
            </div>
        </div>

        <CopyCodeButton />

        <script is:inline>
            (() => {
                let cleanup = () => {};

                const initPostNavigation = () => {
                    cleanup();

                    const tocRail = document.querySelector("[data-toc-rail]");
                    if (!(tocRail instanceof HTMLElement)) {
                        cleanup = () => {};
                        return;
                    }

                    const tocLinks = Array.from(
                        tocRail.querySelectorAll("[data-toc-link]"),
                    );
                    const tocGroups = Array.from(
                        tocRail.querySelectorAll("[data-toc-group]"),
                    );
                    let activeSlug = "top";

                    const setRailOpen = (open) => {
                        tocRail.dataset.open = open ? "true" : "false";
                    };

                    const openGroup = (slug) => {
                        tocGroups.forEach((group) => {
                            if (!(group instanceof HTMLElement)) return;
                            group.dataset.open =
                                slug &&
                                group.dataset.tocGroup === slug &&
                                group.dataset.hasChildren === "true"
                                    ? "true"
                                    : "false";
                        });
                    };

                    const setActiveHeading = (slug) => {
                        activeSlug = slug;
                        tocLinks.forEach((link) => {
                            link.dataset.active =
                                link.getAttribute("data-toc-link") === slug
                                    ? "true"
                                    : "false";
                        });

                        const activeChildLink = tocRail.querySelector(
                            `[data-parent-slug][data-toc-link="${slug}"]`,
                        );

                        if (activeChildLink instanceof HTMLElement) {
                            openGroup(activeChildLink.dataset.parentSlug);
                            return;
                        }

                        openGroup(null);
                    };

                    const groupListeners = [];

                    tocGroups.forEach((group) => {
                        if (!(group instanceof HTMLElement)) return;

                        const slug = group.dataset.tocGroup;
                        if (!slug) return;

                        const onEnter = () => {
                            setRailOpen(true);
                            openGroup(
                                group.dataset.hasChildren === "true"
                                    ? slug
                                    : null,
                            );
                        };

                        group.addEventListener("mouseenter", onEnter);
                        groupListeners.push(() =>
                            group.removeEventListener("mouseenter", onEnter),
                        );
                    });

                    const onRailEnter = () => setRailOpen(true);
                    const onRailLeave = () => {
                        setRailOpen(false);
                        setActiveHeading(activeSlug);
                    };

                    tocRail.addEventListener("mouseenter", onRailEnter);
                    tocRail.addEventListener("mouseleave", onRailLeave);

                    const headingElements = tocLinks
                        .map((link) => {
                            const slug = link.getAttribute("data-toc-link");
                            if (!slug) return null;

                            const element = document.getElementById(slug);
                            if (!element) return null;

                            return { slug, element };
                        })
                        .filter(Boolean);

                    const observer = new IntersectionObserver(
                        (entries) => {
                            const visibleEntries = entries
                                .filter((entry) => entry.isIntersecting)
                                .sort(
                                    (a, b) =>
                                        a.boundingClientRect.top -
                                        b.boundingClientRect.top,
                                );

                            if (visibleEntries.length === 0) return;
                            setActiveHeading(visibleEntries[0].target.id);
                        },
                        {
                            rootMargin: "-18% 0px -68% 0px",
                            threshold: [0, 1],
                        },
                    );

                    headingElements.forEach((heading) =>
                        observer.observe(heading.element),
                    );

                    setActiveHeading(headingElements[0]?.slug || "top");
                    setRailOpen(false);

                    cleanup = () => {
                        observer.disconnect();
                        tocRail.removeEventListener("mouseenter", onRailEnter);
                        tocRail.removeEventListener("mouseleave", onRailLeave);
                        groupListeners.forEach((removeListener) =>
                            removeListener(),
                        );
                    };
                };

                document.addEventListener(
                    "DOMContentLoaded",
                    initPostNavigation,
                );
                document.addEventListener(
                    "astro:page-load",
                    initPostNavigation,
                );
            })();
        </script>
    </body>
</html>
