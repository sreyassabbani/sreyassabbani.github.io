---
import { SITE_TITLE } from "../consts";
import ProfilePortrait from "../components/ProfilePortrait.astro";
import Layout from "../layouts/Layout.astro";

const projectAreas = [
  {
    title: "Writing and Notes",
    description:
      "Longer notes on math, physics, and adjacent ideas I want to understand well enough to explain clearly.",
  },
  {
    title: "Software Experiments",
    description:
      "Small tools, website work, and programming detours that feel interesting enough to make real.",
  },
  {
    title: "Learning in Public",
    description:
      "An ongoing record of questions, partial answers, and the useful things that happen while figuring them out.",
  },
];
---

<Layout
  title={`${SITE_TITLE} — About`}
  description="More about Sreyas Sabbani and the kinds of projects he spends time on."
>
  <section class="mx-auto w-full max-w-3xl">
    <section class="flex min-h-[32rem] flex-col items-center justify-center gap-8 py-12 text-center md:min-h-[36rem]">
      <ProfilePortrait
        size="lg"
        className="gap-3"
        imageClassName="ring-1 ring-border"
      />

      <div class="max-w-2xl space-y-4">
        <p class="text-sm text-muted-foreground">About</p>
        <h1 class="font-heading text-4xl font-semibold tracking-tight text-foreground md:text-5xl">
          Sreyas Sabbani
        </h1>
        <p class="text-base leading-8 text-muted-foreground">
          I'm <strong class="text-primary">Sreyas Sabbani</strong>, and I care about mathematics, physics, and computer science, mostly in the
          form of learning carefully and making things that help ideas feel less
          abstract.
        </p>
        <p class="text-base leading-8 text-muted-foreground">
          This site is where that process shows up: notes, experiments,
          occasional insights, and the occasional joke.
        </p>
      </div>
    </section>

    <section id="projects" class="max-w-2xl space-y-4 pb-8 pt-8">
      <div class="max-w-2xl">
        <div class="space-y-3">
          <p class="text-sm text-muted-foreground">Projects</p>
          <h2 class="font-heading text-3xl font-semibold tracking-tight text-foreground">
            A few things I tend to spend time on
          </h2>
          <p class="text-muted-foreground">
            Mostly small, ongoing work rather than a polished catalogue of
            launches.
          </p>
        </div>

        <div class="mt-8 border-t border-border">
          {
            projectAreas.map((area) => (
              <article class="grid gap-3 border-b border-border py-6 md:grid-cols-3 md:gap-6">
                <h3 class="font-heading text-lg font-semibold text-foreground">
                  {area.title}
                </h3>
                <p class="text-muted-foreground md:col-span-2">
                  {area.description}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </section>
</Layout>
