---
import { Image } from "astro:assets";
import type { MarkdownHeading } from "astro";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import CopyCodeButton from "../components/CopyCodeButton.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"blog">["data"] & {
    headings: MarkdownHeading[];
};

type TocItem = {
    slug: string;
    text: string;
};

type TocGroup = {
    heading: TocItem;
    children: TocItem[];
};

const { title, description, pubDate, updatedDate, heroImage, headings } =
    Astro.props as Props;

const filteredHeadings = headings
    .filter(({ depth }) => depth >= 2 && depth <= 3)
    .map(({ depth, slug, text }) => ({ depth, slug, text }));

const tocGroups: TocGroup[] = [];

for (const heading of filteredHeadings) {
    if (heading.depth === 2 || tocGroups.length === 0) {
        tocGroups.push({
            heading: { slug: heading.slug, text: heading.text },
            children: [],
        });
        continue;
    }

    tocGroups[tocGroups.length - 1].children.push({
        slug: heading.slug,
        text: heading.text,
    });
}

const tocEntries =
    tocGroups.length > 0
        ? tocGroups
        : [{ heading: { slug: "top", text: "Top" }, children: [] }];
---

<html lang="en">
    <head>
        <BaseHead title={title} description={description} />
        <style>
            .post-shell {
                width: min(100%, 48rem);
                margin: 0 auto;
                padding: 1.5rem 1.5rem 3rem;
            }

            .post-shell footer {
                width: min(100%, 46rem);
                margin: 6.4rem auto 0;
                padding-top: 1.55rem;
                border-top: 1px solid var(--border);
                color: color-mix(in oklab, var(--foreground) 42%, var(--background));
                font-size: 0.82rem;
                text-align: center;
            }

            .post-topbar,
            .post-header,
            .post-hero,
            .post-prose {
                width: min(100%, 46rem);
                margin-left: auto;
                margin-right: auto;
            }

            .post-topbar {
                margin-bottom: 1.4rem;
            }

            .post-back {
                display: inline-flex;
                align-items: center;
                gap: 0.45rem;
                color: var(--muted-foreground);
                text-decoration: none;
                font-size: 0.88rem;
            }

            .post-back:hover {
                color: var(--foreground);
            }

            .post-hero {
                margin-bottom: 1.5rem;
                border: 1px solid var(--border);
                border-radius: 1rem;
                overflow: hidden;
                background: var(--card);
            }

            .post-hero img {
                display: block;
                width: 100%;
                height: auto;
            }

            .post-header {
                margin-bottom: 3rem;
                text-align: center;
            }

            .post-date {
                margin: 0;
                font-size: 0.9rem;
                color: var(--muted-foreground);
            }

            .post-updated {
                margin: 0.32rem 0 0;
                font-size: 0.82rem;
                color: var(--muted-foreground);
            }

            .post-title {
                margin: 0.9rem 0 0;
                font-size: clamp(2.1rem, 1.55rem + 1.55vw, 3rem);
                line-height: 1.02;
                letter-spacing: -0.04em;
                text-wrap: balance;
            }

            .post-description {
                margin: 0.95rem auto 0;
                max-width: 35rem;
                font-size: 1rem;
                line-height: 1.72;
                color: var(--muted-foreground);
                text-wrap: pretty;
            }

            .post-divider {
                width: min(15rem, 34%);
                margin: 1.3rem auto 0;
                border: 0;
                border-top: 1px solid var(--border);
            }

            .post-prose :is(h2, h3, h4, h5, h6)[id] {
                scroll-margin-top: 1.5rem;
            }

            .toc-rail {
                display: none;
            }

            @media (min-width: 1100px) {
                .toc-rail {
                    position: fixed;
                    inset: 0 auto 0 0;
                    display: block;
                    width: 14rem;
                    z-index: 20;
                }

                .toc-hitbox {
                    position: absolute;
                    inset: 0 auto 0 0;
                    width: 1.8rem;
                    pointer-events: auto;
                }

                .toc-panel {
                    position: absolute;
                    top: 50%;
                    left: 0;
                    width: 13.25rem;
                    max-height: calc(100vh - 2rem);
                    overflow-y: auto;
                    padding: 0.75rem 0.7rem;
                    border-right: 1px solid var(--border);
                    border-top: 1px solid var(--border);
                    border-bottom: 1px solid var(--border);
                    border-radius: 0 0.95rem 0.95rem 0;
                    background: color-mix(
                        in oklab,
                        var(--card) 94%,
                        var(--secondary)
                    );
                    transform: translate(-86%, -50%);
                    opacity: 0;
                    pointer-events: none;
                    transition: transform 0.52s cubic-bezier(0.22, 1, 0.36, 1),
                        opacity 0.44s ease;
                }

                .toc-rail:hover .toc-panel,
                .toc-rail[data-open="true"] .toc-panel {
                    transform: translate(0, -50%);
                    opacity: 1;
                    pointer-events: auto;
                    transition: transform 0.34s cubic-bezier(0.22, 1, 0.36, 1),
                        opacity 0.28s ease;
                }
            }

            .toc-list,
            .toc-children {
                list-style: none;
                margin: 0;
                padding: 0;
            }

            .toc-group + .toc-group {
                margin-top: 0.16rem;
            }

            .toc-group-link,
            .toc-child-link {
                display: block;
                padding: 0.2rem 0.35rem;
                border-radius: 0.55rem;
                color: var(--muted-foreground);
                text-decoration: none;
            }

            .toc-group-link {
                font-size: 0.76rem;
                line-height: 1.4;
            }

            .toc-child-link {
                font-size: 0.7rem;
                line-height: 1.35;
            }

            .toc-group-link:hover,
            .toc-child-link:hover {
                color: var(--foreground);
                background: color-mix(in oklab, var(--secondary) 76%, transparent);
            }

            .toc-group-link[data-active="true"],
            .toc-child-link[data-active="true"] {
                color: var(--foreground);
                background: color-mix(in oklab, var(--secondary) 92%, transparent);
            }

            .toc-children {
                max-height: 0;
                opacity: 0;
                overflow: hidden;
                margin-left: 0.55rem;
                padding-left: 0.55rem;
                border-left: 1px solid transparent;
                transition: max-height 0.36s cubic-bezier(0.22, 1, 0.36, 1),
                    opacity 0.28s ease, border-color 0.28s ease,
                    margin-top 0.28s ease;
            }

            .toc-group[data-open="true"] .toc-children {
                max-height: 12rem;
                opacity: 1;
                margin-top: 0.16rem;
                border-left-color: var(--border);
            }

            .toc-children li + li {
                margin-top: 0.08rem;
            }
        </style>
    </head>

    <body
        id="top"
        class="bg-[color:var(--background)] text-[color:var(--foreground)]"
    >
        <aside class="toc-rail" data-toc-rail aria-label="Post sections">
            <div class="toc-hitbox" aria-hidden="true"></div>
            <div class="toc-panel">
                <nav>
                    <ul class="toc-list">
                        {tocEntries.map((group) => (
                            <li
                                class="toc-group"
                                data-toc-group={group.heading.slug}
                                data-has-children={
                                    group.children.length > 0
                                        ? "true"
                                        : "false"
                                }
                            >
                                <a
                                    class="toc-group-link"
                                    href={`#${group.heading.slug}`}
                                    data-toc-link={group.heading.slug}
                                >
                                    {group.heading.text}
                                </a>
                                <ul
                                    class="toc-children"
                                    data-toc-children={group.heading.slug}
                                >
                                    {group.children.map((child) => (
                                        <li>
                                            <a
                                                class="toc-child-link"
                                                href={`#${child.slug}`}
                                                data-toc-link={child.slug}
                                                data-parent-slug={group.heading.slug}
                                            >
                                                {child.text}
                                            </a>
                                        </li>
                                    ))}
                                </ul>
                            </li>
                        ))}
                    </ul>
                </nav>
            </div>
        </aside>

        <div class="post-shell">
            <main>
                <div class="post-topbar">
                    <a class="post-back" href="/blog">Back</a>
                </div>

                <article>
                    {
                        heroImage && (
                            <figure class="post-hero">
                                <Image
                                    width={1020}
                                    height={510}
                                    src={heroImage}
                                    alt=""
                                />
                            </figure>
                        )
                    }

                    <header class="post-header">
                        <p class="post-date">
                            <FormattedDate date={pubDate} />
                        </p>
                        {
                            updatedDate && (
                                <p class="post-updated">
                                    Updated <FormattedDate date={updatedDate} />
                                </p>
                            )
                        }
                        <h1 class="post-title">{title}</h1>
                        {
                            description && (
                                <p class="post-description">{description}</p>
                            )
                        }
                        <hr class="post-divider" />
                    </header>

                    <div class="prose post-prose">
                        <slot />
                    </div>
                </article>
            </main>

            <Footer />
        </div>

        <CopyCodeButton />

        <script is:inline>
            (() => {
                let cleanup = () => {};

                const initPostNavigation = () => {
                    cleanup();

                    const tocRail = document.querySelector("[data-toc-rail]");
                    if (!(tocRail instanceof HTMLElement)) {
                        cleanup = () => {};
                        return;
                    }

                    const tocLinks = Array.from(
                        tocRail.querySelectorAll("[data-toc-link]"),
                    );
                    const tocGroups = Array.from(
                        tocRail.querySelectorAll("[data-toc-group]"),
                    );
                    let activeSlug = "top";

                    const setRailOpen = (open) => {
                        tocRail.dataset.open = open ? "true" : "false";
                    };

                    const openGroup = (slug) => {
                        tocGroups.forEach((group) => {
                            if (!(group instanceof HTMLElement)) return;
                            group.dataset.open =
                                slug &&
                                group.dataset.tocGroup === slug &&
                                group.dataset.hasChildren === "true"
                                    ? "true"
                                    : "false";
                        });
                    };

                    const setActiveHeading = (slug) => {
                        activeSlug = slug;
                        tocLinks.forEach((link) => {
                            link.dataset.active =
                                link.getAttribute("data-toc-link") === slug
                                    ? "true"
                                    : "false";
                        });

                        const activeChildLink = tocRail.querySelector(
                            `[data-parent-slug][data-toc-link="${slug}"]`,
                        );

                        if (activeChildLink instanceof HTMLElement) {
                            openGroup(activeChildLink.dataset.parentSlug);
                            return;
                        }

                        openGroup(null);
                    };

                    const groupListeners = [];

                    tocGroups.forEach((group) => {
                        if (!(group instanceof HTMLElement)) return;

                        const slug = group.dataset.tocGroup;
                        if (!slug) return;

                        const onEnter = () => {
                            setRailOpen(true);
                            openGroup(
                                group.dataset.hasChildren === "true"
                                    ? slug
                                    : null,
                            );
                        };

                        group.addEventListener("mouseenter", onEnter);
                        groupListeners.push(() =>
                            group.removeEventListener("mouseenter", onEnter),
                        );
                    });

                    const onRailEnter = () => setRailOpen(true);
                    const onRailLeave = () => {
                        setRailOpen(false);
                        setActiveHeading(activeSlug);
                    };

                    tocRail.addEventListener("mouseenter", onRailEnter);
                    tocRail.addEventListener("mouseleave", onRailLeave);

                    const headingElements = tocLinks
                        .map((link) => {
                            const slug = link.getAttribute("data-toc-link");
                            if (!slug) return null;

                            const element = document.getElementById(slug);
                            if (!element) return null;

                            return { slug, element };
                        })
                        .filter(Boolean);

                    const observer = new IntersectionObserver(
                        (entries) => {
                            const visibleEntries = entries
                                .filter((entry) => entry.isIntersecting)
                                .sort(
                                    (a, b) =>
                                        a.boundingClientRect.top -
                                        b.boundingClientRect.top,
                                );

                            if (visibleEntries.length === 0) return;
                            setActiveHeading(visibleEntries[0].target.id);
                        },
                        {
                            rootMargin: "-18% 0px -68% 0px",
                            threshold: [0, 1],
                        },
                    );

                    headingElements.forEach((heading) =>
                        observer.observe(heading.element),
                    );

                    setActiveHeading(headingElements[0]?.slug || "top");
                    setRailOpen(false);

                    cleanup = () => {
                        observer.disconnect();
                        tocRail.removeEventListener("mouseenter", onRailEnter);
                        tocRail.removeEventListener("mouseleave", onRailLeave);
                        groupListeners.forEach((removeListener) =>
                            removeListener(),
                        );
                    };
                };

                document.addEventListener(
                    "DOMContentLoaded",
                    initPostNavigation,
                );
                document.addEventListener(
                    "astro:page-load",
                    initPostNavigation,
                );
            })();
        </script>
    </body>
</html>
