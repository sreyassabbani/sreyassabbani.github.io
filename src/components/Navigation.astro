---
import ThemeToggle from "./ThemeToggle.astro";

const navLinkClass =
    "group relative flex items-center justify-center pb-1 text-sm font-medium text-foreground no-underline transition-colors duration-200 hover:text-primary";
const navUnderlineClass =
    "absolute inset-x-0 bottom-0 h-px origin-left scale-x-0 bg-primary transition-transform duration-300 group-hover:scale-x-100";
const socialLinkClass =
    "flex size-8 items-center justify-center rounded-full text-foreground transition-colors duration-200 hover:bg-secondary hover:text-primary sm:size-9";
const iconClass = "size-4 fill-current sm:size-[1.1rem]";
---

<nav
  class="flex w-full flex-col gap-3 border-b border-border pb-3 pt-2 text-sm text-foreground sm:flex-row sm:items-center sm:justify-between sm:gap-6 sm:pb-4"
>
  <div class="flex items-center justify-between gap-3 sm:min-w-0">
    <a
      href="/"
      class="flex min-w-0 flex-1 items-center no-underline hover:text-foreground sm:flex-none"
    >
      <span class="block font-brand text-[clamp(1.8rem,8vw,2.35rem)] leading-none font-semibold tracking-tight">
        <span>sreyas</span><span class="text-primary">.is</span>
      </span>
    </a>
    <ThemeToggle class="shrink-0 sm:hidden" />
  </div>

  <div class="flex items-center justify-between gap-4 sm:ml-auto sm:justify-end sm:gap-5">
    <div class="flex items-center gap-4 sm:gap-5">
      <a href="/blog" class={navLinkClass}>
        Blog
        <span class={navUnderlineClass}></span>
      </a>
      <a href="/about" class={navLinkClass}>
        More
        <span class={navUnderlineClass}></span>
      </a>
    </div>

    <div class="flex items-center gap-1 sm:gap-2">
      <a
        class={socialLinkClass}
        target="_blank"
        rel="noopener noreferrer"
        href="https://github.com/sreyassabbani"
        aria-label="GitHub"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class={iconClass}
          width="24"
          height="24"
          viewBox="0 0 24 24"
        >
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
      </a>
      <a
        class={socialLinkClass}
        target="_blank"
        rel="noopener noreferrer"
        href="https://www.linkedin.com/in/sreyassabbani"
        aria-label="LinkedIn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class={iconClass}
          width="24"
          height="24"
          viewBox="0 0 24 24"
        >
          <path
            d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
          ></path>
        </svg>
      </a>
      <a
        class={socialLinkClass}
        target="_blank"
        rel="noopener noreferrer"
        href="mailto:sreyassabbani@gmail.com"
        aria-label="Email"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="size-5 fill-current"
          width="24"
          height="24"
          viewBox="0 0 24 24"
        >
          <path d="M0 0h24v24H0z" fill="none"></path>
          <path
            d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2m-.4 4.25-6.54 4.09c-.65.41-1.47.41-2.12 0L4.4 8.25c-.25-.16-.4-.43-.4-.72 0-.67.73-1.07 1.3-.72L12 11l6.7-4.19c.57-.35 1.3.05 1.3.72 0 .29-.15.56-.4.72"
          ></path>
        </svg>
      </a>
      <ThemeToggle class="hidden shrink-0 sm:inline-flex" />
    </div>
  </div>
</nav>
