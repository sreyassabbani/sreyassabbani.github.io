---
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import ProfilePortrait from "../components/ProfilePortrait.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title={`${SITE_TITLE} — Home`}
  description={SITE_DESCRIPTION}
  variant="home"
>
  <section class="flex flex-col gap-8 md:flex-row md:items-center">
    <ProfilePortrait className="w-full md:w-1/4" />
    <div class="w-full space-y-4 text-left md:w-3/4">
      <h1 class="font-heading text-2xl font-semibold text-foreground">
        hi there!
      </h1>
      <p class="text-muted-foreground">
        I'm a math, physics, and CS enthusiast.
      </p>

      <p class="text-muted-foreground">
        I enjoy learning and tinkering with things; this website has daily
        struggles, occasional insights, and even some jokes I find funny 😄
      </p>
    </div>
  </section>
</Layout>
