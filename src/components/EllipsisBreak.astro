---
interface Props {
    className?: string;
}

const { className = "" } = Astro.props;
---

<div class:list={["my-10 flex justify-center", className]} aria-hidden="true">
    <span class="flex items-center gap-2 text-muted-foreground/80">
        <span class="size-1 rounded-full bg-current"></span>
        <span class="size-1 rounded-full bg-current"></span>
        <span class="size-1 rounded-full bg-current"></span>
    </span>
</div>
